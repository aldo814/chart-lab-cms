{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "lib": ["dom", "ES2017"],
    "checkJs": false
  },
  "include": [
    "sanity.config.ts",
    "sanity.cli.ts",
    "schemas/**/*",
    "plugins/**/*",
    "components/**/*"
  ]
}